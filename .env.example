# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM / embeddings provider --------------------------------------------
# Default (no AGENT_* vars): OpenAI — chat gpt-5-nano + embeddings
# text-embedding-3-small. Just set OPENAI_API_KEY and you're done.
OPENAI_API_KEY=

# To run free on Google Gemini instead, leave OPENAI_API_KEY empty and set the
# AGENT_* overrides below (both chat and embeddings point at Gemini's
# OpenAI-compatible endpoint). NOTE: switching the embedding provider changes the
# vector space — re-ingest the RAG store afterwards:
#   python -m agent.rag.ingest --rebuild
#
# AGENT_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AGENT_LLM_API_KEY=<your-gemini-api-key>
# AGENT_LLM_MODEL=gemini-2.0-flash
# AGENT_LLM_MAX_TOKENS_PARAM=max_tokens
# AGENT_EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AGENT_EMBED_API_KEY=<your-gemini-api-key>
# AGENT_EMBED_MODEL=text-embedding-004

# Tavily — web search fallback (#A2 web_search)
TAVILY_API_KEY=

# Langfuse — observability (#B4)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Set to 1 to use the offline LLM mock (tests without hitting the API).
AGENT_LLM_MOCK=
