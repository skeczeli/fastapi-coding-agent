# Copy to .env and fill in. .env is gitignored — never commit real keys.

# OpenAI — LLM (gpt-5-nano) + embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# Tavily — web search fallback (#A2 web_search)
TAVILY_API_KEY=

# Langfuse — observability (#B4)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Set to 1 to use the offline LLM mock (tests without hitting the API).
AGENT_LLM_MOCK=
